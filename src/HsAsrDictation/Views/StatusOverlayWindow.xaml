<Window x:Class="HsAsrDictation.Views.StatusOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        AllowsTransparency="True"
        Background="Transparent"
        Focusable="False"
        ResizeMode="NoResize"
        ShowActivated="False"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        Topmost="True"
        WindowStyle="None">
    <Border Padding="18,12"
            CornerRadius="14"
            Background="#DD101820"
            BorderBrush="#66FFFFFF"
            BorderThickness="1"
            SnapsToDevicePixels="True">
        <StackPanel MaxWidth="720">
            <TextBlock x:Name="StatusTextBlock"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="White"
                       Text="录音中" />
            <TextBlock x:Name="PreviewTextBlock"
                       Margin="0,6,0,0"
                       FontSize="14"
                       Foreground="#E6FFFFFF"
                       TextWrapping="Wrap"
                       Visibility="Collapsed" />
        </StackPanel>
    </Border>
</Window>
