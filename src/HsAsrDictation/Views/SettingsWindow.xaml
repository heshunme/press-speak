<Window x:Class="HsAsrDictation.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HsAsrDictation 设置"
        Width="520"
        Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Margin="0,0,12,12"
                   VerticalAlignment="Center"
                   Text="输入设备" />
        <ComboBox Grid.Row="0"
                  Grid.Column="1"
                  Margin="0,0,0,12"
                  DisplayMemberPath="ProductName"
                  ItemsSource="{Binding Devices}"
                  SelectedValue="{Binding SelectedDeviceName}"
                  SelectedValuePath="ProductName" />

        <TextBlock Grid.Row="1"
                   Grid.Column="0"
                   Margin="0,0,12,12"
                   VerticalAlignment="Center"
                   Text="热键主键" />
        <ComboBox Grid.Row="1"
                  Grid.Column="1"
                  Margin="0,0,0,12"
                  ItemsSource="{Binding AvailableKeys}"
                  SelectedItem="{Binding SelectedKey}" />

        <TextBlock Grid.Row="2"
                   Grid.Column="0"
                   Margin="0,0,12,12"
                   VerticalAlignment="Top"
                   Text="热键修饰键" />
        <StackPanel Grid.Row="2"
                    Grid.Column="1"
                    Margin="0,0,0,12"
                    Orientation="Horizontal">
            <CheckBox Margin="0,0,12,0" Content="Ctrl" IsChecked="{Binding UseCtrl}" />
            <CheckBox Margin="0,0,12,0" Content="Alt" IsChecked="{Binding UseAlt}" />
            <CheckBox Margin="0,0,12,0" Content="Shift" IsChecked="{Binding UseShift}" />
            <CheckBox Content="Win" IsChecked="{Binding UseWindows}" />
        </StackPanel>

        <TextBlock Grid.Row="3"
                   Grid.Column="0"
                   Margin="0,0,12,12"
                   VerticalAlignment="Center"
                   Text="离线模型目录" />
        <TextBox Grid.Row="3"
                 Grid.Column="1"
                 Margin="0,0,0,12"
                 Text="{Binding OfflineModelRootPath}" />

        <TextBlock Grid.Row="4"
                   Grid.Column="0"
                   Margin="0,0,12,12"
                   VerticalAlignment="Center"
                   Text="流式模型目录" />
        <TextBox Grid.Row="4"
                 Grid.Column="1"
                 Margin="0,0,0,12"
                 Text="{Binding StreamingModelRootPath}" />

        <TextBlock Grid.Row="5"
                   Grid.Column="0"
                   Margin="0,0,12,12"
                   VerticalAlignment="Center"
                   Text="识别模式" />
        <ComboBox Grid.Row="5"
                  Grid.Column="1"
                  Margin="0,0,0,12"
                  ItemsSource="{Binding RecognitionModes}"
                  SelectedItem="{Binding SelectedRecognitionMode}" />

        <TextBlock Grid.Row="6"
                   Grid.Column="0"
                   Margin="0,0,12,12"
                   VerticalAlignment="Top"
                   Text="选项" />
        <StackPanel Grid.Row="6"
                    Grid.Column="1"
                    Margin="0,0,0,12">
            <CheckBox Content="缺模型时自动下载" IsChecked="{Binding AutoDownloadModel}" />
            <CheckBox Content="SendInput 失败时允许剪贴板回退" IsChecked="{Binding AllowClipboardFallback}" />
            <CheckBox Content="启用标点" IsChecked="{Binding EnablePunctuation}" />
            <CheckBox Content="启用实时流式预览" IsChecked="{Binding EnableStreamingPreview}" />
        </StackPanel>

        <Border Grid.Row="7"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="0,8,0,16"
                Padding="12"
                Background="#FFF6F6F6"
                CornerRadius="6">
            <TextBlock TextWrapping="Wrap">
                首版仅支持 Windows 11 x64。模型默认下载到本地应用数据目录，首次准备模型时间较长属于正常现象。
            </TextBlock>
        </Border>

        <StackPanel Grid.Row="8"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="96"
                    Margin="0,0,12,0"
                    Click="Cancel_Click"
                    Content="取消" />
            <Button Width="96"
                    Click="Save_Click"
                    Content="保存" />
        </StackPanel>
    </Grid>
</Window>
