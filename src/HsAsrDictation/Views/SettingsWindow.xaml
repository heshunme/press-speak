<Window x:Class="HsAsrDictation.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="HsAsrDictation 设置"
        Width="1120"
        Height="810"
        MinWidth="1050"
        MinHeight="740"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <x:Array x:Key="RuleKindOptions" Type="{x:Type sys:String}">
            <sys:String>exact_replace</sys:String>
            <sys:String>regex_replace</sys:String>
        </x:Array>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <TabItem Header="常规设置">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Margin="0,0,12,12"
                               VerticalAlignment="Center"
                               Text="输入设备" />
                    <ComboBox Grid.Row="0"
                              Grid.Column="1"
                              Margin="0,0,0,12"
                              DisplayMemberPath="ProductName"
                              ItemsSource="{Binding Devices}"
                              SelectedValue="{Binding SelectedDeviceName}"
                              SelectedValuePath="ProductName" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Margin="0,0,12,12"
                               VerticalAlignment="Top"
                               Text="唤起热键" />
                    <StackPanel Grid.Row="1"
                                Grid.Column="1"
                                Margin="0,0,0,12"
                                Orientation="Vertical">
                        <TextBox x:Name="HotkeyCaptureTextBox"
                                 Margin="0,0,0,8"
                                 IsReadOnly="True"
                                 Focusable="True"
                                 Text="{Binding HotkeyDisplayText}" />
                        <Button Width="96"
                                Margin="0,0,0,8"
                                HorizontalAlignment="Left"
                                Click="ToggleHotkeyCapture_Click"
                                Content="{Binding HotkeyCaptureButtonText}" />
                        <TextBlock Foreground="#FF666666"
                                   Text="{Binding HotkeyCapturePrompt}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Margin="0,0,12,12"
                               VerticalAlignment="Center"
                               Text="离线模型目录" />
                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Margin="0,0,0,12"
                             Text="{Binding OfflineModelRootPath}" />

                    <TextBlock Grid.Row="3"
                               Grid.Column="0"
                               Margin="0,0,12,12"
                               VerticalAlignment="Center"
                               Text="流式模型目录" />
                    <TextBox Grid.Row="3"
                             Grid.Column="1"
                             Margin="0,0,0,12"
                             Text="{Binding StreamingModelRootPath}" />

                    <TextBlock Grid.Row="4"
                               Grid.Column="0"
                               Margin="0,0,12,12"
                               VerticalAlignment="Center"
                               Text="识别模式" />
                    <ComboBox Grid.Row="4"
                              Grid.Column="1"
                              Margin="0,0,0,12"
                              ItemsSource="{Binding RecognitionModes}"
                              SelectedItem="{Binding SelectedRecognitionMode}" />

                    <TextBlock Grid.Row="5"
                               Grid.Column="0"
                               Margin="0,0,12,12"
                               VerticalAlignment="Top"
                               Text="选项" />
                    <StackPanel Grid.Row="5"
                                Grid.Column="1"
                                Margin="0,0,0,12">
                        <CheckBox Content="缺模型时自动下载" IsChecked="{Binding AutoDownloadModel}" />
                        <CheckBox Content="SendInput 失败时允许剪贴板回退" IsChecked="{Binding AllowClipboardFallback}" />
                        <CheckBox Content="启用标点" IsChecked="{Binding EnablePunctuation}" />
                        <CheckBox Content="启用实时流式预览" IsChecked="{Binding EnableStreamingPreview}" />
                    </StackPanel>

                    <Border Grid.Row="6"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Margin="0,8,0,0"
                            Padding="12"
                            Background="#FFF6F6F6"
                            CornerRadius="6">
                        <TextBlock TextWrapping="Wrap">
                            首版仅支持 Windows 11 x64。模型默认下载到本地应用数据目录，首次准备模型时间较长属于正常现象。
                        </TextBlock>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="后处理规则">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <CheckBox Content="启用后处理规则"
                                  IsChecked="{Binding PostProcessing.IsRuleSystemEnabled}" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="#FF666666"
                                   Text="作用于最终写回文本，失败时自动回退原文本。"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Margin="0,0,0,12"
                                Orientation="Horizontal">
                        <Button Width="88" Margin="0,0,8,0" Click="AddRule_Click" Content="新增规则" />
                        <Button Width="88" Margin="0,0,8,0" Click="DuplicateRule_Click" Content="复制规则" />
                        <Button Width="88" Margin="0,0,8,0" Click="DeleteRule_Click" Content="删除/禁用" />
                        <Button Width="72" Margin="0,0,8,0" Click="MoveRuleUp_Click" Content="上移" />
                        <Button Width="72" Margin="0,0,8,0" Click="MoveRuleDown_Click" Content="下移" />
                        <Button Width="88" Click="ResetRule_Click" Content="恢复默认" />
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.45*" MinWidth="380" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="2.55*" MinWidth="560" />
                        </Grid.ColumnDefinitions>

                        <DataGrid Grid.Column="0"
                                  MinWidth="380"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  IsReadOnly="False"
                                  ItemsSource="{Binding PostProcessing.Rules}"
                                  SelectedItem="{Binding PostProcessing.SelectedRule, Mode=TwoWay}">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Width="56" Binding="{Binding IsEnabled}" Header="启用" />
                                <DataGridTextColumn Width="64" Binding="{Binding Order}" Header="顺序" />
                                <DataGridTextColumn Width="120" Binding="{Binding Name}" Header="名称" />
                                <DataGridTextColumn Width="96" Binding="{Binding KindDisplay}" Header="类型" IsReadOnly="True" />
                                <DataGridCheckBoxColumn Width="56" Binding="{Binding IsBuiltIn}" Header="内置" IsReadOnly="True" />
                                <DataGridTextColumn Width="*" Binding="{Binding Description}" Header="描述" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Column="2"
                                Padding="10"
                                Background="#FFF8F8F8"
                                BorderBrush="#FFE0E0E0"
                                BorderThickness="1"
                                CornerRadius="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           FontWeight="SemiBold"
                                           Text="规则详情" />
                                <TextBlock Grid.Row="1"
                                           Margin="0,4,0,12"
                                           Foreground="#FF666666"
                                           Text="选中左侧规则后可编辑详情；内置规则支持修改并可恢复默认。"
                                           TextWrapping="Wrap" />

                                <Grid Grid.Row="2"
                                      Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="56" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="48" />
                                        <ColumnDefinition Width="72" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               VerticalAlignment="Center"
                                               Text="名称" />
                                    <TextBox Grid.Column="1"
                                             Height="28"
                                             Text="{Binding PostProcessing.SelectedRule.Name, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Column="3"
                                               VerticalAlignment="Center"
                                               Text="顺序" />
                                    <TextBox Grid.Column="4"
                                             Height="28"
                                             Text="{Binding PostProcessing.SelectedRule.Order, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <Grid Grid.Row="3"
                                      Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="56" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               VerticalAlignment="Center"
                                               Text="类型" />
                                    <ComboBox Grid.Column="1"
                                              Height="28"
                                              IsEnabled="{Binding PostProcessing.SelectedRule.IsKindEditable}"
                                              ItemsSource="{StaticResource RuleKindOptions}"
                                              SelectedItem="{Binding PostProcessing.SelectedRule.Kind}" />
                                    <StackPanel Grid.Column="3"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock Margin="0,0,8,0"
                                                   VerticalAlignment="Center"
                                                   Text="状态" />
                                        <CheckBox VerticalAlignment="Center"
                                                  IsChecked="{Binding PostProcessing.SelectedRule.IsEnabled}" />
                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="4"
                                      Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="56" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Margin="0,4,0,0"
                                               VerticalAlignment="Top"
                                               Text="描述" />
                                    <TextBox Grid.Column="1"
                                             AcceptsReturn="True"
                                             Height="48"
                                             Text="{Binding PostProcessing.SelectedRule.Description, UpdateSourceTrigger=PropertyChanged}"
                                             TextWrapping="Wrap" />
                                </Grid>

                                <TextBlock Grid.Row="5"
                                           Margin="0,0,0,8"
                                           FontWeight="SemiBold"
                                           Text="规则参数" />

                                <Grid Grid.Row="6"
                                      Visibility="{Binding PostProcessing.SelectedRule.IsExactReplace, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="64" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               VerticalAlignment="Center"
                                               Text="查找文本" />
                                    <TextBox Grid.Row="0"
                                             Grid.Column="1"
                                             Height="28"
                                             Text="{Binding PostProcessing.SelectedRule.FindText, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               Margin="0,10,0,0"
                                               VerticalAlignment="Center"
                                               Text="替换文本" />
                                    <TextBox Grid.Row="1"
                                             Grid.Column="1"
                                             Margin="0,10,0,0"
                                             Height="28"
                                             Text="{Binding PostProcessing.SelectedRule.ReplaceText, UpdateSourceTrigger=PropertyChanged}" />
                                    <CheckBox Grid.Row="2"
                                              Grid.Column="1"
                                              Margin="0,10,0,0"
                                              Content="忽略大小写"
                                              IsChecked="{Binding PostProcessing.SelectedRule.IgnoreCase}" />
                                </Grid>

                                <Grid Grid.Row="6"
                                      Visibility="{Binding PostProcessing.SelectedRule.IsRegexReplace, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="96" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Margin="0,4,0,0"
                                               VerticalAlignment="Top"
                                               Text="Pattern" />
                                    <TextBox Grid.Row="0"
                                             Grid.Column="1"
                                             AcceptsReturn="True"
                                             Height="56"
                                             Text="{Binding PostProcessing.SelectedRule.Pattern, UpdateSourceTrigger=PropertyChanged}"
                                             TextWrapping="Wrap" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               Margin="0,10,0,0"
                                               VerticalAlignment="Center"
                                               Text="Replacement" />
                                    <TextBox Grid.Row="1"
                                             Grid.Column="1"
                                             Margin="0,10,0,0"
                                             Height="28"
                                             Text="{Binding PostProcessing.SelectedRule.Replacement, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Row="2"
                                               Grid.Column="0"
                                               Margin="0,10,0,0"
                                               VerticalAlignment="Center"
                                               Text="Options" />
                                    <TextBox Grid.Row="2"
                                             Grid.Column="1"
                                             Margin="0,10,0,0"
                                             Height="28"
                                             Text="{Binding PostProcessing.SelectedRule.RegexOptions, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <Grid Grid.Row="6"
                                      Visibility="{Binding PostProcessing.SelectedRule.IsBuiltInTransform, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="80" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               VerticalAlignment="Center"
                                               Text="Transform" />
                                    <TextBox Grid.Row="0"
                                             Grid.Column="1"
                                             Height="28"
                                             IsReadOnly="True"
                                             Text="{Binding PostProcessing.SelectedRule.TransformName}" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               Margin="0,10,0,0"
                                               VerticalAlignment="Center"
                                               Text="最少字母数" />
                                    <TextBox Grid.Row="1"
                                             Grid.Column="1"
                                             Margin="0,10,0,0"
                                             Height="28"
                                             Text="{Binding PostProcessing.SelectedRule.MinLetters, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="3"
                                               Margin="0,10,0,0"
                                               VerticalAlignment="Center"
                                               Text="最多字母数" />
                                    <TextBox Grid.Row="1"
                                             Grid.Column="4"
                                             Margin="0,10,0,0"
                                             Height="28"
                                             Text="{Binding PostProcessing.SelectedRule.MaxLetters, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Grid.Row="3"
                            Margin="0,12,0,0"
                            Padding="12"
                            Height="200"
                            MinHeight="200"
                            Background="#FFF6F6F6"
                            CornerRadius="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       FontWeight="SemiBold"
                                       Text="测试区" />
                            <Button Grid.Row="0"
                                    Grid.Column="1"
                                    Width="88"
                                    Click="TestRules_Click"
                                    Content="测试" />

                            <Grid Grid.Row="1"
                                  Grid.Column="0"
                                  Grid.ColumnSpan="2"
                                  Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="0,0,0,4"
                                               Text="输入文本" />
                                    <TextBox AcceptsReturn="True"
                                             Height="112"
                                             Text="{Binding PostProcessing.TestInput, UpdateSourceTrigger=PropertyChanged}"
                                             TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="0,0,0,4"
                                               Text="输出文本" />
                                    <TextBox AcceptsReturn="True"
                                             Height="112"
                                             IsReadOnly="True"
                                             Text="{Binding PostProcessing.TestOutput}"
                                             TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Grid.Column="4">
                                    <TextBlock Margin="0,0,0,4"
                                               Text="执行 Trace" />
                                    <TextBox AcceptsReturn="True"
                                             Height="112"
                                             IsReadOnly="True"
                                             Text="{Binding PostProcessing.TestTrace}"
                                             TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="96"
                    Margin="0,0,12,0"
                    Click="Cancel_Click"
                    Content="取消" />
            <Button Width="96"
                    Click="Save_Click"
                    Content="保存" />
        </StackPanel>
    </Grid>
</Window>
